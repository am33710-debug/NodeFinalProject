<!DOCTYPE html>
<html>
<head><title>Faculties</title></head>
<body>

    <!-- ADD FACULTY TO A UNIVERSITY -->
    <h2>Add Faculty</h2>
    <form action="/faculties/create" method="POST">
        <input type="text" name="name" placeholder="Name" required>
        <input type="text" name="address" placeholder="Address" required>
        <select name="universityId" required>
            <% universities.forEach(u => { %>
                <option value="<%= u._id %>"><%= u.name %></option>
            <% }); %>
        </select>
        <button type="submit">Add</button>
    </form>

    <hr>

    <!-- FILTER FACULTIES BY UNIVERSITY (WHAT UNIVERSITY HAS WHAT FACULTIES) -->
    <h2>Faculties by University</h2>
    <form action="/" method="GET">
        <select name="universityId">
            <option value="">-- All --</option>
            <% universities.forEach(u => { %>
                <option value="<%= u._id %>" <%= selectedUniId === u._id.toString() ? "selected" : "" %>>
                    <%= u.name %>
                </option>
            <% }); %>
        </select>
        <button type="submit">Filter</button>
    </form>

    <ul>
        <% faculties.forEach(f => { %>
            <li><%= f.name %> — <%= f.address %></li>
        <% }); %>
    </ul>

</body>
</html>